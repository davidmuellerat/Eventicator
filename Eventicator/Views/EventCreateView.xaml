<ContentPage
    x:Class="Eventicator.Views.EventCreateView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:Eventicator.ViewModels">

    <ContentPage.BindingContext>
        <viewmodels:EventCreateViewModel />
    </ContentPage.BindingContext>

    <VerticalStackLayout Padding="20" Spacing="10">

        <Label Text="Create Event" FontSize="24"/>

        <Entry Text="{Binding Title}" Placeholder="Title"/>
        <Entry Text="{Binding Location}" Placeholder="Location"/>
        <Editor Text="{Binding Description}" Placeholder="Description"/>
        <DatePicker Date="{Binding Date}"/>

        <Button Text="Create" Command="{Binding CreateCommand}"/>

    </VerticalStackLayout>
</ContentPage>
