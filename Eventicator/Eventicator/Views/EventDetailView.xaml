<ContentPage
    x:Class="Eventicator.Views.EventDetailView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:Eventicator.ViewModels">

    <ContentPage.Content>
        <VerticalStackLayout Padding="20" Spacing="10">

            <Label Text="Event Details" FontSize="24" FontAttributes="Bold"/>

            <Entry Text="{Binding Event.Title}" Placeholder="Title"/>
            <Entry Text="{Binding Event.Location}" Placeholder="Location"/>
            <Editor Text="{Binding Event.Description}" Placeholder="Description"/>
            <DatePicker Date="{Binding Event.Date}"/>

            <HorizontalStackLayout Spacing="10">
                <Button Text="Save" Command="{Binding SaveCommand}" />
                <Button Text="Delete" Command="{Binding DeleteCommand}" TextColor="Red"/>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ContentPage.Content>

</ContentPage>
