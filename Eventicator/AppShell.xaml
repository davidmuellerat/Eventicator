<?xml version="1.0" encoding="UTF-8" ?>
<Shell                                                                                                                                  
       x:Class="Eventicator.AppShell"                                                                                                      
       xmlns="http://schemas.microsoft.com/dotnet/2021/maui"                                                                               
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"                                                                              
       xmlns:views="clr-namespace:Event icator.Views">

    <!-- Start: Login -->
    <ShellContent                                                                                                                       
           Title="Login"                                                                                                                   
           Route="login"                                                                                                                   
           ContentTemplate="{DataTemplate views:LoginView}" />

    <!-- Hauptseite: Events -->
    <ShellContent                                                                                                                       
           Title="Events"                                                                                                                  
           Route="events"                                                                                                                  
           ContentTemplate="{DataTemplate views:EventListView}" />

</Shell>   